<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Animation Container for Musical Notes -->
    <FrameLayout
        android:id="@+id/animationContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="JukeBox"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <!-- Metronome Button -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="12dp">

                    <Button
                        android:id="@+id/button1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="#E57373"
                        android:gravity="top|start"
                        android:padding="8dp"
                        android:text="Metronome"
                        app:cornerRadius="8dp" />

                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="180dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="-20dp"
                        android:layout_marginBottom="40dp"
                        android:alpha="0.2"
                        android:contentDescription="Metronome Background Icon"
                        android:rotation="-15"
                        android:scaleType="centerCrop"
                        android:src="@drawable/metronome_icon" />
                </FrameLayout>

                <!-- Tuner Button -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="12dp">

                    <Button
                        android:id="@+id/button2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="#64B5F6"
                        android:gravity="top|start"
                        android:padding="8dp"
                        android:text="Tuner"
                        app:cornerRadius="8dp" />

                    <ImageView
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="40dp"
                        android:layout_marginEnd="-30dp"
                        android:alpha="0.2"
                        android:contentDescription="Tuner Background Icon"
                        android:rotation="-65"
                        android:scaleType="centerCrop"
                        android:src="@drawable/tuner_icon" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <!-- Sheet Music Button -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="12dp">

                    <Button
                        android:id="@+id/button3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="#81C784"
                        android:gravity="top|start"
                        android:padding="8dp"
                        android:text="Sheet Music Reader/Playback"
                        app:cornerRadius="8dp" />

                    <ImageView
                        android:layout_width="180dp"
                        android:layout_height="200dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="40dp"
                        android:layout_marginEnd="-40dp"
                        android:alpha="0.2"
                        android:contentDescription="Sheet Music Background Icon"
                        android:rotation="-15"
                        android:scaleType="centerCrop"
                        android:src="@drawable/music_sheet_icon" />
                </FrameLayout>

                <!-- Transcriptor Button -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="12dp">

                    <Button
                        android:id="@+id/button4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:backgroundTint="#FFB74D"
                        android:gravity="top|start"
                        android:padding="8dp"
                        android:text="Transcriptor"
                        app:cornerRadius="8dp" />

                    <ImageView
                        android:layout_width="180dp"
                        android:layout_height="200dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginBottom="40dp"
                        android:layout_marginEnd="-40dp"
                        android:alpha="0.2"
                        android:contentDescription="Transcriptor Background Icon"
                        android:rotation="-15"
                        android:scaleType="centerCrop"
                        android:src="@drawable/music_transcription_icon" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>