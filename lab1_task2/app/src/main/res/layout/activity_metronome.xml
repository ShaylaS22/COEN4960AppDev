<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/metronomeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E57373"
    android:padding="16dp">

    <Button
        android:id="@+id/btnBack"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:text="Back"
        android:textColor="@android:color/white"
        app:icon="@drawable/ic_back_arrow"
        app:iconGravity="textStart"
        app:iconTint="@android:color/white" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Tap Tempo Indicator -->
        <TextView
            android:id="@+id/tvTapIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● TAP TEMPO ACTIVE"
            android:textColor="#FFEB3B"
            android:textStyle="bold"
            android:visibility="invisible"
            android:layout_marginBottom="8dp" />

        <ImageView
            android:id="@+id/ivMetronome"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_marginBottom="32dp"
            android:scaleType="fitCenter"
            android:src="@drawable/metronome_1"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Metronome Visualizer" />

        <EditText
            android:id="@+id/etBpm"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:inputType="number"
            android:hint="BPM"
            android:textColor="@android:color/white"
            android:textColorHint="#CCFFFFFF"
            android:textSize="20sp" />

        <Button
            android:id="@+id/btnPlaySound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Start Metronome"
            android:backgroundTint="@android:color/white"
            android:textColor="#E57373" />

        <TextView
            android:id="@+id/tvMetronomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Metronome Activity"
            android:textColor="@android:color/white"
            android:textSize="24sp" />
    </LinearLayout>

</RelativeLayout>